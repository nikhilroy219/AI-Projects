    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================================\n// SENTINEL — Weighted Risk Scoring Algorithm\n// ============================================================\n\n// --- INPUT DATA ---\n// IP geo data from HTTP Request via Merge input\nconst ip_country = $input.item.json.countryCode || 'XX';\nconst is_proxy = $input.item.json.proxy || false;\nconst is_hosting = $input.item.json.hosting || false;\n\n// Transaction data — handle both flat and nested webhook body (n8n version differences)\nconst _wh = $('Webhook').item.json;\nconst _txn = (_wh.body && typeof _wh.body === 'object') ? _wh.body : _wh;\nconst billing_country = $('Set').item.json.billing_country || _txn.billing_country;\nconst amount_eur = parseFloat($('Set').item.json.amount_eur || _txn.amount_eur);\nconst timestamp = $('Set').item.json.timestamp || _txn.timestamp;\nconst customer_id = $('Set').item.json.customer_id || _txn.customer_id;\nconst transaction_id = $('Set').item.json.transaction_id || _txn.transaction_id;\nconst customer_email = $('Set').item.json.customer_email || _txn.customer_email || '';\nconst ip_address = $('Set').item.json.ip_address || _txn.ip_address;\n\n// Velocity and amount deviation from parallel Google Sheets branches\nconst velocity_count = parseInt($input.item.json.velocity_count || 0);\nconst historical_average = parseFloat($input.item.json.historical_average || 200);\n\n// --- PARAMETER 1: GEO MISMATCH (weight 0.30) ---\nlet risk_geo = 0;\nif (is_proxy || is_hosting) {\n  risk_geo = 90; // VPN or hosting provider — very high risk\n} else if (ip_country !== billing_country) {\n  risk_geo = 65; // Country mismatch — elevated risk\n} else {\n  risk_geo = 5; // Same country — low risk\n}\n\n// --- PARAMETER 2: VELOCITY (weight 0.25) ---\nlet risk_velocity = 0;\nif (velocity_count >= 5) {\n  risk_velocity = 95;\n} else if (velocity_count >= 3) {\n  risk_velocity = 65;\n} else if (velocity_count >= 1) {\n  risk_velocity = 30;\n} else {\n  risk_velocity = 5;\n}\n\n// --- PARAMETER 3: AMOUNT DEVIATION (weight 0.20) ---\nlet risk_amount = 0;\nconst deviation_ratio = historical_average > 0 ? amount_eur / historical_average : 10;\nif (deviation_ratio >= 5) {\n  risk_amount = 90; // 5x or more above average\n} else if (deviation_ratio >= 3) {\n  risk_amount = 70; // 3x above average\n} else if (deviation_ratio >= 2) {\n  risk_amount = 40; // 2x above average\n} else {\n  risk_amount = 10; // Normal range\n}\n\n// --- PARAMETER 4: TIME OF DAY (weight 0.15) ---\nlet risk_time = 0;\nconst txn_date = new Date(timestamp);\nconst hour_utc = txn_date.getUTCHours();\nif (hour_utc >= 2 && hour_utc <= 5) {\n  risk_time = 80; // 2am to 5am UTC — high risk window\n} else if (hour_utc >= 23 || hour_utc <= 1) {\n  risk_time = 40; // Late night — moderate risk\n} else {\n  risk_time = 5; // Business hours — low risk\n}\n\n// --- PARAMETER 5: EMAIL RISK (weight 0.10) ---\nlet risk_email = 0;\nconst disposable_domains = [\n  'tempmail.com', 'guerrillamail.com', 'mailinator.com',\n  'throwam.com', 'yopmail.com', 'trashmail.com', '10minutemail.com',\n  'sharklasers.com', 'guerrillamailblock.com', 'grr.la'\n];\nconst email_domain = customer_email.split('@')[1] || '';\nif (disposable_domains.includes(email_domain)) {\n  risk_email = 95;\n} else if (!email_domain.includes('.')) {\n  risk_email = 70;\n} else {\n  risk_email = 5;\n}\n\n// --- WEIGHTED FINAL SCORE ---\nconst final_score = Math.round(\n  (0.30 * risk_geo) +\n  (0.25 * risk_velocity) +\n  (0.20 * risk_amount) +\n  (0.15 * risk_time) +\n  (0.10 * risk_email)\n);\n\n// --- RISK LEVEL ---\nlet risk_level = '';\nlet action_taken = '';\nif (final_score >= 75) {\n  risk_level = 'HIGH';\n  action_taken = 'FROZEN';\n} else if (final_score >= 50) {\n  risk_level = 'MEDIUM';\n  action_taken = 'FLAGGED';\n} else {\n  risk_level = 'LOW';\n  action_taken = 'PASSED';\n}\n\n// --- OUTPUT ---\nreturn {\n  json: {\n    transaction_id,\n    timestamp,\n    customer_id,\n    customer_email,\n    amount_eur,\n    ip_address: ip_address,\n    ip_country,\n    billing_country,\n    is_proxy,\n    risk_geo,\n    risk_velocity,\n    risk_amount,\n    risk_time,\n    risk_email,\n    final_score,\n    risk_level,\n    action_taken,\n    historical_average,\n    velocity_count\n  }\n};"
      },
