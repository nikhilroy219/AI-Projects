    {
      "parameters": {
        "jsCode": "// Compute historical average amount for this customer\n// Runs on ALL items (including 0 items if sheet is empty) so Merge always receives 1 item\nconst items = $input.all();\nconst _wh3 = $('Webhook').item.json;\nconst _b3 = (_wh3.body && typeof _wh3.body === 'object') ? _wh3.body : _wh3;\nconst customer_id = $('Set').item.json.customer_id || _b3.customer_id;\n\nconst customerTransactions = items.filter(item => {\n  return (item.json['Customer ID'] || '') === customer_id;\n});\n\nlet historical_average = 200; // default if no history exists\n\nif (customerTransactions.length > 0) {\n  const total = customerTransactions.reduce((sum, item) => {\n    return sum + parseFloat(item.json['Amount (EUR)'] || 0);\n  }, 0);\n  historical_average = Math.round((total / customerTransactions.length) * 100) / 100;\n}\n\nreturn [{ json: { historical_average } }];"
      },
