      "parameters": {
        "jsCode": "// Compute velocity: count transactions by this customer in the last 60 minutes\n// Runs on ALL items (including 0 items if sheet is empty) so Merge always receives 1 item\nconst items = $input.all();\nconst _wh2 = $('Webhook').item.json;\nconst _b2 = (_wh2.body && typeof _wh2.body === 'object') ? _wh2.body : _wh2;\nconst customer_id = $('Set').item.json.customer_id || _b2.customer_id;\nconst now = new Date();\nconst oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000);\n\nlet velocity_count = 0;\n\nfor (const item of items) {\n  const rowCustomerId = item.json['Customer ID'] || '';\n  const rowTimestamp = item.json['Timestamp'] || '';\n\n  if (rowCustomerId === customer_id && rowTimestamp) {\n    const txnTime = new Date(rowTimestamp);\n    if (!isNaN(txnTime.getTime()) && txnTime >= oneHourAgo) {\n      velocity_count++;\n    }\n  }\n}\n\nreturn [{ json: { velocity_count } }];"
      },
