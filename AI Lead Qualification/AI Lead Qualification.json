        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"sonar\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Research this company: {{ $('Loop Over Items').item.json['Company Name'] }}. Find: 1) Their official website URL 2) Their area of specialisation in energy or industrial tech 3) Latest news or development in the last 30 days relevant to their growth, funding, expansion, or partnerships in Europe. Be specific and factual.\"\n    }\n  ]\n}",
