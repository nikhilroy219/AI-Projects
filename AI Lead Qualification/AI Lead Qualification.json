    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const response = $json;\n\nif (response.stop_reason === 'max_tokens') {\n  throw new Error('Claude response was truncated. Increase max_tokens.');\n}\n\nconst raw = response.content?.[0]?.text;\n\nif (!raw) {\n  throw new Error('Claude returned no text.');\n}\n\nconst clean = raw\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(clean);\n} catch (error) {\n  throw new Error(\n    `Claude returned invalid JSON: ${error.message}\\n\\n${clean}`\n  );\n}\n\nreturn {\n  json: {\n    company_name: String(parsed.company_name ?? ''),\n    aos: String(parsed.aos ?? ''),\n    link: String(parsed.link ?? ''),\n    news_and_leverage: String(parsed.news_and_leverage ?? ''),\n    last_updated: new Date().toLocaleDateString('en-GB')\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
